@code {

    EZSendRequest model = new();

    [CascadingParameter]
    public EventCallback<string> notifyUser { get; set; }
    public Dictionary<string, object> Parameters { get; set; } = new Dictionary<string, object>();

    AceDataCollector aceDataCollector;
    List<EZSendRequestData> ezsendList = new();

    List<Type> selectedList = new();
    public DisplayOptionStatus displayOptionStatus;
    public InputQueryParameters inputQueryParameters;
    private string idValue = string.Empty;
    LoggerUtility loggerUtility;
    string urlInteractive = string.Empty;
    bool loadingError = true;
    bool showPhoneErrorMessage = false;
    bool showSuccessMessage = false;
    bool showErrorMessage = false;
    string errorResponseMessage = "";
    bool phoneValid = false;
    EditContext editContext;
    string headingDisplay = string.Empty;
    DateTime startDate, endDate;
    bool hideGetTransaction = true;
    bool savedSourceSystemData = false;
    SourceSystemBaseEntity tempSourceSystemEntity;
    bool saveDocDetailsInDB = false;
    private int? CategoryId { get; set; } = null;
    private int? DocumentId { get; set; } = null;

    protected override async Task OnInitializedAsync()
    {
        startDate = endDate = DateTime.Now.Date;
        inputQueryParameters = new InputQueryParameters(NavigationManager.Uri);
        displayOptionStatus = new DisplayOptionStatus(inputQueryParameters);
        loggerUtility = new LoggerUtility(NavigationManager.BaseUri, displayOptionStatus.DisplayText);
        headingDisplay = displayOptionStatus.DisplayText;
        editContext = new EditContext(model);
        model.PhoneNumberMessageShown = true ? model.phoneNumber != "" : false;

        ShowSpinner();
        await GetUserData();  // siteminder
        GetIdFromURI();
        await GetEzSend();
        await UpdateEZSendRequest();
        HideSpinner();

        Parameters.Add(ApplicationConstants.LookupData, aceDataCollector);
        Parameters.Add("Logger", loggerUtility);
    }

    //Get ID from URI
    private void GetIdFromURI()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("id", out var id))
        {
            idValue = id;
        }
    }

    async Task GetEzSend()
    {
        try
        {
            var ezsendList = await Http.GetFromJsonAsync<List<EZSendRequestData>>($"{ApplicationConstants.UrlEzsendRequest}?Id={idValue}");

            // Handle the case where the response is null or empty
            if (ezsendList == null || ezsendList.Count == 0)
            {
                loggerUtility.LogInfoAsync(LogType.Error, $"EzSend List Empty");
            }
            else
            {
                var ezsendRequest = ezsendList.OrderByDescending(x => x.CreatedDateTime).FirstOrDefault();

                if (ezsendRequest != null)
                {
                    // Deserialize the payload string into a PayloadData object
                    var payloadData = JsonSerializer.Deserialize<EZSendRequest>(ezsendRequest.Payload);
                    model.Id = ezsendRequest.Id;
                    model.userId = ezsendRequest.UserId;
                    model.csfEffective = payloadData.documentFlowData.csfEffective;
                    model.policyEffectiveDate = payloadData.documentFlowData.policyEffectiveDate; //DG-19809
                    model.PANJMBuyersGuideFlag = payloadData.documentFlowData.PANJMBuyersGuideFlag;
                    model.policyNumber = payloadData.documentFlowData.policyNumber;
                    model.transactionType = payloadData.documentFlowData.transactionType;
                    model.jobLob = payloadData.documentFlowData.jobLob;
                    model.jobNumber = payloadData.documentFlowData.jobNumber;
                    model.jobState = payloadData.documentFlowData.jobState;
                    model.documentFlow = payloadData.documentFlow;
                    model.documentSessionID = payloadData.documentSessionID;
                    model.emailAddress = payloadData.emailAddress;
                    model.emailAddressText = payloadData.emailAddress;
                    model.sourceSystem = payloadData.sourceSystem;
                    model.returnURL = payloadData.returnURL;
                    model.Status = payloadData.Status;
                    model.documentFlowData = payloadData.documentFlowData; 
                    model.PaperlessDocList = payloadData.documentFlowData.PaperlessDocList;
                    // Format the phone number string to match the expected format
                    string formattedPhoneNumber = String.IsNullOrEmpty(payloadData.phoneNumber) ? String.Empty : string.Format("({0}) {1}-{2}", payloadData.phoneNumber.Substring(0, 3), payloadData.phoneNumber.Substring(3, 3), payloadData.phoneNumber.Substring(6, 4));
                    model.phoneNumber = formattedPhoneNumber;
                    model.UserName = payloadData.documentFlowData.userName;

                    PackageName();
                } else {
                    loggerUtility.LogInfoAsync(LogType.Error, $"EzSend List Empty");
                }                
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex.Message);
            loadingError = true;
        }
    }

    private string PackageName()
    {
        if (model.jobState == "CT")
        {
            return model.PackageName = model.jobState + " " + "Informed Consent Package";
        }

        //12523 PL MD state - Technical story (EZ Send API) - New Business and Policy change
        if (model.transactionType == "Reinstatement")
        {
            return model.PackageName = model.jobState + " " + "Reinstatement CSF Package";
        }

        return model.PackageName = model.jobState + " " + model.documentFlow + " " + "Package";


    }

