    //     {
    //         var result = await Http.GetFromJsonAsync<String>($"{ApplicationConstants.UrlUpdateEZSendUser}?Id={model.Id}&UserId={inputQueryParameters.UserDetails.UserID}");
    //         Console.WriteLine($"Update User ID: {result}");    

    //     }
