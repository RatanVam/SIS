<EditForm Model="@model" OnSubmit="@OnSubmit">
    <RadzenCard class="my-5 mx-auto" Style="max-width: 650px;">        
        @if (model.IsPaperless) //conditional UI for Paperless
        {
            <DataAnnotationsValidator />

            <RadzenRow class="rz-text-align-left rz-border-color-info" Gap="1rem"Style="width:600px; margin:auto;">
                <RadzenColumn class="rz-background-color-base-200 rz-p-3 rz-color-base-800">
                    <h2 id="paperless_header">Send Paperless Link</h2>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow class="rz-text-align-left rz-border-color-base-100"
                       Style="width:600px; margin:10px auto 0 auto;">
                <RadzenColumn class="rz-p-3 rz-m-0" Style="width:100%;">

                    <label style="font-weight:bold;">Send to Email Address:</label>

                    <RadzenRow>
                        <RadzenColumn>
                            <RadzenTextBox id="PaperlessEmailAddress"@bind-Value="model.emailAddress" Style="width:100%; margin-top:5px;" MaxLength="60" />
                            <div class="ml-4 rz-color-danger">
                                <ValidationMessage For="() => model.emailAddress" />
                            </div>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow Style="margin-top:10px;">
                        <RadzenColumn>
                            <p style="color:#555;">
                                We will email this address when a new document is available. This email will
                                sync to the Preferred Email on the account and will be used for all policies enrolled in paperless.
                            </p>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow Style="margin-top:20px;">
                        <RadzenColumn>
                            <p style="font-weight:bold;">Send the following required documents:</p>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenRow>
                        <RadzenColumn>
                            <ul>
                                @foreach (var doc in (model.documentFlowData.PaperlessDocList?.Split(",") ?? Array.Empty<string>())
                                            .Select(d => d.Trim()).Select(d => model.documentFlowData.jobState == "CT" && d.Equals("CT Consent Package", StringComparison.OrdinalIgnoreCase)
                                            ? "CT Informed Consent Package": d).OrderByDescending(d => d.Equals("Paperless Consent", StringComparison.OrdinalIgnoreCase)))
                                {
                                    <li>@doc</li>
                                }
                            </ul>
                        </RadzenColumn>
                    </RadzenRow>

                </RadzenColumn>
            </RadzenRow>
        }
        else
        {           
            <RadzenRow class="rz-text-align-left rz-border-color-info" Gap="1rem" Style="width:600px; margin:auto;">
                <RadzenColumn class="rz-background-color-base-200 rz-p-3 rz-color-base-800">
                    <h2 id="coverage_forms_header"> Send Coverage Forms Link</h2>
                    <p>Please review the information below and make any changes as needed. Click 'Send Link' to continue or 'Cancel' to go back.</p>

                    <DataAnnotationsValidator />
                    <p>
                        @* <ValidationSummary /> *@
                    </p>
                </RadzenColumn>
            </RadzenRow>
            @if (model.policyNumber == null)
            {
                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                    <RadzenColumn class="rz-p-3 rz-color-base-800">

                        <span style="display:inline-block"><span id="quote_number_label" style=" font-weight:bold; margin-right:5px;">Quote number </span></span>

                    </RadzenColumn>
                    <RadzenColumn class="rz-p-3 rz-color-base-800">
                        <span id="quote_number"> @model.jobNumber </span>
                        <RadzenText id="JobNumber" @bind-Value="model.jobNumber"></RadzenText>
                    </RadzenColumn>


                </RadzenRow>
            }
            @if (model.policyNumber != null)
            {
                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap
                ="1rem" Style
                ="width:600px; margin:auto;">
                    <RadzenColumn class="rz-p-3 rz-color-base-800">

                        <span style="display:inline-block"><span id="policy_number_label" style=" font-weight:bold; margin-right:5px;">Policy number </span></span>

                    </RadzenColumn>
                    <RadzenColumn class="rz-p-3 rz-color-base-800">
                        <span id="policy_number"> @model.policyNumber </span>
                        <RadzenText id="PolicyNumber" @bind-Value="model.policyNumber"></RadzenText>
                    </RadzenColumn>

                </RadzenRow>
            }
            @if (model.csfEffective != null && model.policyNumber != null)
            {
                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap
                ="1rem" Style
                ="width:600px; margin:auto;">
                    <RadzenColumn class="rz-p-3 rz-color-base-800">

                        <span style="display:inline-block"><span id="csf_Effective_label" style=" font-weight:bold; margin-right:5px;">CSF Effective </span></span>

                    </RadzenColumn>
                    <RadzenColumn class="rz-p-3 rz-color-base-800">
                        <span id="csf_Effective"> @model.csfEffective </span>
                        <RadzenText id="PolicyNumber" @bind-Value="model.csfEffective"></RadzenText>
                    </RadzenColumn>

                </RadzenRow>
            }
            <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                <RadzenColumn class="rz-p-3 rz-color-base-800">
                    <label for="PackageName"><span id="package_name_label" style="font-weight:bold; margin-right:5px;">Package Name </span></label>

                </RadzenColumn>
                <RadzenColumn class="rz-p-3 rz-color-base-800">

                    <select id="PackageName" class="form-control select-with-caret">
                        <option value="O" selected>@model.PackageName</option>
                    </select>

                </RadzenColumn>
            </RadzenRow>

            <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                <RadzenColumn class="rz-p-3 rz-color-base-800 d-flex align-items-center">
                    <RadzenText><span id="send_link_to_label" style="font-weight:bold">Send link to </span></RadzenText>
                </RadzenColumn>
                <RadzenColumn class="rz-p-3 rz-color-base-800">
                    <select id="select_option" @onchange="OnChangeContactMethod" class="form-control select-with-caret">
                        <option value="" selected>--Select Option--</option>
                        <option id = "select_text "value="Text">Text</option>
                        <option id = "select_email "value="Email">Email</option>
                    </select>
                </RadzenColumn>
            </RadzenRow>

            <br />
            <!-- Conditional Input Fields -->
            @if (model.ContactMethod == "Text")
            {               

                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                    <RadzenColumn class="  rz-p-3 rz-color-base-800 d-flex align-items-center">
                        <label for="PhoneNumber"><span id="text_mobile_number_label" style="font-weight:bold;">Mobile Number* </span></label>
                    </RadzenColumn>
                    <RadzenColumn class="rz-p-3 rz-color-base-800">
                        @* <InputText id="PhoneNumber" @bind-Value="model.PhoneNumber"></InputText> *@
                        <RadzenMask id="text_mobile_number" Mask="(***) ***-****" CharacterPattern="[0-9]" Placeholder="" @bind-Value="@model.phoneNumber" Name="PhoneNumber"
                                    Style="width: 100%;" aria-label="Phone" />
                    </RadzenColumn>
                </RadzenRow>
                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                    <RadzenColumn class="  rz-p-3 rz-color-base-800 d-flex align-items-center">
                        <label for="text_email_address"><span id="text_email_label" style="font-weight:bold">Email </span></label>
                    </RadzenColumn>
                    <RadzenColumn class="  rz-p-3 rz-color-base-800">
                        <RadzenTextBox id="text_email_address" @bind-Value="model.emailAddressText" Style="width: 100%;"></RadzenTextBox>
                    </RadzenColumn>
                </RadzenRow>
                <div class="ml-4 rz-color-danger"><ValidationMessage For="()=>model.emailAddressText" /> </div>

                <div class="ml-4 rz-color-danger">
                    <ValidationMessage For="()=>model.phoneNumber" />
                    @if (showPhoneErrorMessage)//API validation message
                    {
                        <p>Please enter a valid mobile number.</p>
                    }
                </div>

            }
            else if (model.ContactMethod == "Email")
            {
                <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
                    <RadzenColumn class="  rz-p-3 rz-color-base-800 d-flex align-items-center">
                        <label><span id="email_email_label" style="font-weight:bold">Email* </span></label>
                    </RadzenColumn>
                    <RadzenColumn class="  rz-p-3 rz-color-base-800">
                        <RadzenTextBox id="EmailAddress" @bind-Value="model.emailAddress" Style="width: 100%;"></RadzenTextBox>
                    </RadzenColumn>
                </RadzenRow>
                <div class="ml-4 rz-color-danger"><ValidationMessage For="()=>model.emailAddress" /> </div>
            }
                             
        }        
        <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
            <RadzenColumn class="rz-background-color-base-100 rz-p-3 rz-color-base-800">

                <div class="col-md-12 d-flex align-items-end justify-content-left mt-4">
                    <RadzenButton id="button_send" ButtonType="ButtonType.Submit" Icon="save" Text="Send Link" ButtonStyle="ButtonStyle.Secondary" Disabled="@(model.IsPaperless ? false : string.IsNullOrEmpty(model.ContactMethod))" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="cancel" style="margin-left: 10px;" Text="Cancel" Click="@Cancel" />
                </div>
            </RadzenColumn>
        </RadzenRow>
        <RadzenRow class="rz-text-align-left rz-border-color-base-100" Gap="1rem" Style="width:600px; margin:auto;">
            <RadzenColumn class="rz-background-color-base-100 rz-p-3 rz-color-base-800">
                @if (showSuccessMessage)
                {
                    <div class="alert alert-success" role="alert">
                        The link was sent successfully!
                    </div>
                }
                else if (showErrorMessage)
                {
                    <div class="alert alert-danger" role="alert">
                        @errorResponseMessage
                    </div>
                }
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
</EditForm>
