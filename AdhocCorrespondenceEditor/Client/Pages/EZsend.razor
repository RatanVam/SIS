    async Task UpdateEZSendRequest()
    {
        try
        {
            ShowSpinner();

            // Changed to GetAsync to manually process the response.
            var response = await Http.GetAsync($"{ApplicationConstants.UrlUpdateEZSendUser}?Id={model.Id}&UserId={inputQueryParameters.UserDetails.UserID}");
            // Response from the repository
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                // Check for empty or whitespace content
                if (!string.IsNullOrWhiteSpace(content))
                {

                    loggerUtility.LogInfoAsync(LogType.Information, content);
                }
                else
                {
                    loggerUtility.LogInfoAsync(LogType.Information, "Empty content");
                }
            }
            else
            {
                loggerUtility.LogInfoAsync(LogType.Error, $"Error: {response.StatusCode} - {response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex);
        }
        finally
        {
            HideSpinner();
        }
    }



    async Task UpdateEzSendStatus()
    {
        try
        {
            ShowSpinner();
            // Changed to GetAsync to manually process the response.
            var response = await Http.GetAsync($"{ApplicationConstants.UrlUpdateEZSendStatus}?Status={(int)model.Status}&Id={model.Id}");
            // Response from the repository
            var content = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                // Check for empty or whitespace content
                if (!string.IsNullOrWhiteSpace(content))
                {
                    loggerUtility.LogInfoAsync(LogType.Information, content);
                }
                else
                {
                    loggerUtility.LogInfoAsync(LogType.Information, "Empty content");
                }
            }
            else
            {
                loggerUtility.LogInfoAsync(LogType.Error, $"Error: {response.StatusCode} - {response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex);
        }
        finally
        {
            HideSpinner();
        }
    }





    async Task GetUserData()
    {
        try
        {
            var user = await Http.GetFromJsonAsync<AdhocCorrespondenceEditor.Shared.UserData>(ApplicationConstants.UrlUser);
            if (!user.IsAuthericated)
            {
                loggerUtility.LogInfoAsync(LogType.Warning, "Invalid User");
                NavigationManager.NavigateTo("./Public/AccessDenied.html", true);
                return;
            }
            urlInteractive = await Http.GetStringAsync(ApplicationConstants.UrlLookupGetWebServiceSearch);
            inputQueryParameters.UserDetails = new Client.UserData
            {
                UserName = user.UserName,
                UserRoles = user.UserRoles ?? string.Empty,
                UserInitials = user.UserInital,
                UserID = user.UserID
            };
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex);
        }
    }
    bool rendered = false;
    protected override void OnAfterRender(bool firstRender)
    {
        if (!string.IsNullOrEmpty(inputQueryParameters.UserDetails?.UserName) && !rendered)
        {
            rendered = true;
            notifyUser.InvokeAsync(inputQueryParameters.UserDetails.UserName);
        }
    }


    private async Task SubmitForm()
    {
        try
        {
            ResetMessages();
            ShowSpinner();

            // Map to API model
            EzsendApiSubmit apiSubmit = MapToEzSendSubmit(model);
            
            HttpResponseMessage response = await Http.PostAsJsonAsync($"{ApplicationConstants.UrlSubmitEzSend}", apiSubmit);

            if (response.IsSuccessStatusCode)
            {
                // Process success response
                var message = await response.Content.ReadAsStringAsync();

                showSuccessMessage = true;
                showErrorMessage = false;
                model.Status = RequestStatus.SUCCESS;
                await UpdateEzSendStatus();
                RedirectToPC();
            }
            else
            {
                // Process error response
                var errorMessage = await response.Content.ReadAsStringAsync();
                errorResponseMessage = errorMessage;
                model.Status = RequestStatus.START;
                showErrorMessage = true;
                showSuccessMessage = false;
            }            
        }
        catch (Exception ex)
        {
            showErrorMessage = true;
            errorResponseMessage = $"An error occurred: {ex.Message}";
            loggerUtility.LogInfoAsync(LogType.Error, ex);
        }
        finally
        {
            HideSpinner();
            StateHasChanged();
        }
    }


    EzsendApiSubmit MapToEzSendSubmit(EZSendRequest ezSendRequest)
    {

        try
        {
            //handles the situation when phoneNumber is empty in DB otherwise it coverts it to the format +1\d{10}
            string phoneNumber = ezSendRequest.phoneNumber != "" ? "+1" + new string(ezSendRequest.phoneNumber.Where(char.IsDigit).ToArray()) : String.Empty;
            // string pname = !string.IsNullOrEmpty(ezSendRequest.policyNumber) ? 
            //                       ("SIGN_POLCHANGE" + ezSendRequest.documentFlow + "_" + ezSendRequest.jobState)
            //                       : ("SIGN_" + ezSendRequest.documentFlow + "_" + ezSendRequest.jobState);

            string pname;
            if (ezSendRequest.transactionType == "Reinstatement")
            {
                pname = "SIGN_POLREINSTATE_MD";
            }
            else
            {
                pname = !string.IsNullOrEmpty(ezSendRequest.policyNumber)
                ? ("SIGN_POLCHANGE" + ezSendRequest.documentFlow + "_" + ezSendRequest.jobState)
                : ("SIGN_" + ezSendRequest.documentFlow + "_" + ezSendRequest.jobState);
            }

            var email = "";

            if (model.ContactMethod == "Text")
            { email = model.emailAddressText; }
            else { email = model.emailAddress; }

            return new EzsendApiSubmit
            {
                processName = pname,
                linkType = ezSendRequest.ContactMethod,
                emailAddress = email,
                phoneNumber = phoneNumber,
                sourceSystem = ezSendRequest.sourceSystem.ToUpper(),
                userId = inputQueryParameters.UserDetails.UserID,
                jobNumber = ezSendRequest.jobNumber,
                policyNumber = ezSendRequest.policyNumber,
                documentSessionId = ezSendRequest.documentSessionID,
                stateCode = ezSendRequest.jobState,
                transactionType = ezSendRequest.transactionType,
                policyEffectiveDate = ezSendRequest.policyEffectiveDate,
                PANJMBuyersGuideFlag = ezSendRequest.PANJMBuyersGuideFlag,
                IsPaperless = ezSendRequest.IsPaperless,//DG-20780 Map IsPaperless,IsCSF and jobLob to send to EzSendAPI
                jobLob = ezSendRequest.jobLob,
                IsCSF = ezSendRequest.IsCSF,
                userName = ezSendRequest.UserName
                };
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex);
            throw;
        }
    }



    private async Task ValidatePhone()
    {
        string phone = model.phoneNumber != "" ? "+1" + new string(model.phoneNumber.Where(char.IsDigit).ToArray()) : null;
        string payload = $@"{{""phoneNumber"":""{phone}""}}";

        try
        {
            ShowSpinner();
            Http.DefaultRequestHeaders.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));
            StringContent content = new StringContent(payload, Encoding.UTF8, "application/json");
            HttpResponseMessage response = await Http.PostAsync($"{ApplicationConstants.UrlValidatePhone}", content);

            if (response.IsSuccessStatusCode)
            {

                string responseContent = await response.Content.ReadAsStringAsync();

                // First decode the JSON string
                string decodedJson = JsonSerializer.Deserialize<string>(responseContent);


                // Then deserialize the decoded JSON to the object
                try
                {
                    var phoneValidationResponse = JsonSerializer.Deserialize<EZSendRequest>(decodedJson);
                    if (phoneValidationResponse != null)
                    {
                        model.isMobilePhone = phoneValidationResponse.isMobilePhone;
                    }
                    else
                    {
                        Console.WriteLine("Deserialization returned null, check the JSON format.");
                    }
                }
                catch (JsonException ex)
                {
                    Console.WriteLine($"JSON deserialization error: {ex.Message}");
                    Console.WriteLine($"Problematic JSON: {decodedJson}");
                }
            }
            else
            {
                string errorResponse = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Failed to validate phone. Server responded with error: {errorResponse}");
            }
        }
        catch (Exception ex)
        {
            loggerUtility.LogInfoAsync(LogType.Error, ex);
        }
        finally
        {
            HideSpinner();
        }
    }

    private bool EmailValidate(EditContext editContext)
    {

        var model = editContext.Model as EZSendRequest;
        if (model.ContactMethod != "Email")
        {
            model.isEmailValid = true; // No validation required if not Email method
            return true;
        }

        var isValid = editContext.Validate();
        // Perform validation only if ContactMethod is "Email"
        // Check specific field validity

        model.isEmailValid = !editContext.GetValidationMessages(
        new FieldIdentifier(model, nameof(model.emailAddress))
        ).Any();

        return model.isEmailValid;
    }

    private bool EmailValidateText(EditContext editContext)
    {

        var model = editContext.Model as EZSendRequest;
        var isValid = editContext.Validate();
        // Perform validation only if ContactMethod is "Email"
        // Check specific field validity

        model.isEmailValid = !editContext.GetValidationMessages(
        new FieldIdentifier(model, nameof(model.emailAddressText))
        ).Any();

        return model.isEmailValid;
    }


    private bool UiPhoneValidate(EditContext editContext)
    {

        var isValid = editContext.Validate();
        var model = editContext.Model as EZSendRequest;
        // Check specific field validity for the phone number
        model.isUiPhoneValid = !editContext.GetValidationMessages(
        new FieldIdentifier(model, nameof(model.phoneNumber))
        ).Any();
        return model.isUiPhoneValid;
    }

    private bool ValidatePaperlessEmail(EditContext context)
    {
        var emailField = new FieldIdentifier(model, nameof(model.emailAddress));
        context.NotifyFieldChanged(emailField);
        //Check field validation for Paperless Email field
        var emailErrors = context.GetValidationMessages(emailField);
        return !emailErrors.Any();
    }


    private async void OnSubmit(EditContext context)
    {        
        var eZSendRequest = context.Model as EZSendRequest;
        //Reset UI state messages at the start.
        showSuccessMessage = false;
        showPhoneErrorMessage = false;
        StateHasChanged();
        if (model.IsPaperless)
        {
            bool isValid = ValidatePaperlessEmail(context);

            if (!isValid)
            {
                return;
            }
            // DG-20780 Call SubmitForm with ContactMethod = Email As We will send link by Email
            if (EmailValidate(context))
            {
                ShowSpinner();
                model.ContactMethod = "Email";
                await SubmitForm();
            }
        }
        else
        {
          
            // Handling for "Text" contact method
            if (eZSendRequest.ContactMethod == "Text")
            {
                // UI side validation
                if (EmailValidateText(context) && UiPhoneValidate(context))
                {
                    await ValidatePhone(); // Server-side validation
                    if (eZSendRequest.isMobilePhone && eZSendRequest.isEmailValid)
                    {
                        ShowSpinner();
                        await SubmitForm();
                    }
                    else
                    {
                        showPhoneErrorMessage = true;
                    }
                }
            }
            // Handling for "Email" contact method
            else if (eZSendRequest.ContactMethod == "Email")
            {
                if (EmailValidate(context))
                {
                    ShowSpinner();
                    await SubmitForm();
                }
            }
        }
        HideSpinner();
        StateHasChanged();
    }

    // Method to handle Cancel button click to redirect back to PC
    private void Redirect()
    {
        string returnUrl = model.returnURL + "?jobNumber=" + model.jobNumber + "&status=" + model.Status;
        NavigationManager.NavigateTo(returnUrl);
    }

    private void Cancel()
    {
        Redirect();
    }

    private void RedirectToPC()
    {
        Redirect();
    }

    void ShowSpinner()
    {
        spinner.Show();
        StateHasChanged();
    }

    void HideSpinner(int milliSeconds = 0)
    {
        spinner.Stop(milliSeconds);
        StateHasChanged();
    }

    private void OnChangeContactMethod(ChangeEventArgs e)
    {
        model.ContactMethod = e.Value?.ToString();
        ResetMessages();
        StateHasChanged();
    }

    private bool checkTouched()
    {
        if (model.PhoneNumberMessageShown == false)
        {
            model.PhoneNumberMessageShown = true;
            return false;

        }
        else
        {
            return true;    
        }
    }
    private void ResetMessages()
    {
        showErrorMessage = false;
        showSuccessMessage = false;       
    }

}


