@using AdhocCorrespondenceEditor.Client
@using AdhocCorrespondenceEditor.Client.Common
@using AdhocCorrespondenceEditor.Client.ControlClass
@using AdhocCorrespondenceEditor.Client.PageHelper
@using AdhocCorrespondenceEditor.Shared
@using AdhocCorrespondenceEditor.Shared.DTO.UserInputEntity
@using AdhocCorrespondenceEditor.Shared.WCC
@using static AdhocCorrespondenceEditor.Client.AceDataCollector
@implements IAsyncDisposable
@namespace AdhocCorrespondenceEditor.Client.Shared
<div class="panel panel-primary">
    <div class="panel-heading">
        @claimantContactTopLabel
    </div>
    <div class="panel-body">
            <div class="row">
                <div class="col-md-3">
                    @claimantContactLabel
                </div>
                <div class="col-md-9">
                     <RadzenDropDown id="ClaimantTwo" TValue="PartyAddressUI" class="DropDownSize" Data=@partyList TextProperty="DisplayName" 
                    ValueProperty="PartyID" Change=@(args => OnPartyChanged(args)) AllowClear=true  Placeholder="--Select--" />
                    <span class="alert-dangerMsg" hidden="@(partyList.Count > 0)">@ApplicationConstants.NoDataMsg</span>
                </div>
            </div>
    </div>
</div>
@code {

    public async ValueTask DisposeAsync()
    {
        LookupData.DocumentSubmitted -= new MyEventHandler(DocumentSubmitted);
    }

    [Parameter]
    public AceDataCollector LookupData { get; set; }

    [Parameter]
    public LoggerUtility Logger { get; set; }
    List<PartyAddressUI> partyList = new();
    string claimantContactTopLabel = "Claimant Name (Contacts Two)";
    string claimantContactLabel = "Claimant Name (Contacts Two):";

    bool companyNameContact, claimantContact = false;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            string primaryRolesExcept;
            primaryRolesExcept = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(primaryRolesExcept), LookupData.documentData.documentEntity.DocumentId);
            var partyFullList = (new MapperClass()).GetMappedObjects(LookupData.SourceSystemEntity);
            if (!string.IsNullOrEmpty(primaryRolesExcept))
            {
                var partyRoles = primaryRolesExcept.Split(',').ToList();
                partyList = partyFullList.Where(x => x.PartyRoles.Except(partyRoles).Count() > 0)?.OrderBy(x=>x.DisplayName)?.ToList();
            }

            claimantContactTopLabel = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(claimantContactTopLabel), LookupData.documentData.documentEntity.DocumentId);
            claimantContactLabel = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(claimantContactLabel), LookupData.documentData.documentEntity.DocumentId);
            companyNameContact = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(companyNameContact), LookupData.documentData.documentEntity.DocumentId)?.ToUpper() == bool.TrueString.ToUpper() ? true : false;
            claimantContact = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(claimantContact), LookupData.documentData.documentEntity.DocumentId)?.ToUpper() == bool.TrueString.ToUpper() ? true : false;
        }
        catch (Exception ex)
        {
            Logger.LogInfoAsync(LogType.Error, ex);
        }
        LookupData.DocumentSubmitted += new MyEventHandler(DocumentSubmitted);
    }

    string partyID;
    void OnPartyChanged(object myArgs)
    {
        try
        {
            partyID = myArgs == null ? string.Empty : myArgs.ToString();
        }
        catch (Exception ex)
        {
            Logger.LogInfoAsync(LogType.Error, ex);
        }
    }

    void DocumentSubmitted(bool isValidate)
    {
        if (string.IsNullOrEmpty(partyID))
        {
           // LookupData.errorDetails.IsInValid = true;
            return;
        }
        var name = partyList.Where(x => x.PartyID == partyID).FirstOrDefault()?.DisplayName;
        if(companyNameContact)
        ((GCUserEntity)LookupData.UserSelection).ClaimantNameCompany = name;
        else  if(claimantContact)
        ((GCUserEntity)LookupData.UserSelection).ClaimantNameAddress = new AdhocCorrespondenceEditor.Shared.DTO.UserInputEntity.Address
            {
                DisplayName = name
            };
        else
        ((GCUserEntity)LookupData.UserSelection).ClaimantNameContact2 = name;
    }
}
