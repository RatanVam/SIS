@using AdhocCorrespondenceEditor.Client
@using AdhocCorrespondenceEditor.Client.Common
@using AdhocCorrespondenceEditor.Client.ControlClass
@using AdhocCorrespondenceEditor.Client.PageHelper
@using AdhocCorrespondenceEditor.Shared
@using AdhocCorrespondenceEditor.Shared.DTO.UserInputEntity
@using AdhocCorrespondenceEditor.Shared.GC
@using static AdhocCorrespondenceEditor.Client.AceDataCollector
@implements IAsyncDisposable
@namespace AdhocCorrespondenceEditor.Client.Shared

<div class="panel panel-primary">
    <div class="panel-heading">
        Re: Section
    </div>
    <div class="panel-body">
        <div class="row">
            <div class="col-md-3">
                Label
            </div>
            <div class="col-md-6">
                Reference
            </div>
        </div>
        <hr />
        <div class="row" hidden="@(!showLossLoc)">
            <div class="col-md-3">
                <RadzenSwitch id="LossLocation" @bind-Value=@chkLossLocation />Loss Location:
            </div>
            <div class="col-md-6">
                @txtLossLocation
            </div>
        </div>
                <div class="row">
            <div class="col-md-3">
                <RadzenSwitch id="YourClaimNo" @bind-Value=@chkYourClaimNo />Your Claim No:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="YourClaimNoText" class="@LookupData.GetTextColorClass(txtYourClaimNo, firstRendeValue || !chkYourClaimNo )" Disabled ="@(!chkYourClaimNo)"  @bind-Value=@txtYourClaimNo MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="YourPolicyNo" @bind-Value=@chkYourPolicyNo />Your Policy No:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="YourPolicyNoText" class="@LookupData.GetTextColorClass(txtYourPolicyNo, firstRendeValue || !chkYourPolicyNo )" Disabled ="@(!chkYourPolicyNo)"  @bind-Value=@txtYourPolicyNo MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="YourInsured" @bind-Value=@chkYourInsured />Your Insured:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="YourInsuredText" class="@LookupData.GetTextColorClass(txtYourInsured, firstRendeValue || !chkYourInsured )" Disabled ="@(!chkYourInsured)"  @bind-Value=@txtYourInsured MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="CaseCaption" @bind-Value=@chkCaseCaption />Case Caption:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="CaseCaptiontext" class="@LookupData.GetTextColorClass(txtCaseCaption, firstRendeValue || !chkCaseCaption )" Disabled ="@(!chkCaseCaption)"  @bind-Value=@txtCaseCaption MaxLength="150" Style="width: 100%; max-width: 400px;" /> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="YourClient" @bind-Value=@chkYourClient />Your Client:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="YourClientText" class="@LookupData.GetTextColorClass(txtYourClient, firstRendeValue || !chkYourClient )" Disabled ="@(!chkYourClient)"  @bind-Value=@txtYourClient MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="YourFileNo" @bind-Value=@chkYourFileNo />Your File No:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="YourFileNoText" class="@LookupData.GetTextColorClass(txtYourFileNo, firstRendeValue || !chkYourFileNo )" Disabled ="@(!chkYourFileNo)"  @bind-Value=@txtYourFileNo MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                        <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="DateofService" @bind-Value=@chkDateofService />Date(s) of Service:
            </div>
            <div class="col-md-6">
               <RadzenTextBox id="DateofServicetext" class="@LookupData.GetTextColorClass(txtDateofService, firstRendeValue || !chkDateofService )" Disabled ="@(!chkDateofService)"  @bind-Value=@txtDateofService MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
            </div>
        </div>
                                <div class="row" >
            <div class="col-md-3">
                <RadzenSwitch id="Claimant" @bind-Value=@chkClaimant />Claimant:
            </div>
            <div class="col-md-9">
                   <RadzenDropDown id="ClaimantDD" TValue="PartyAddressUI" class="@LookupData.GetTextColorClass(partyID, firstRendeValue || !chkClaimant)" Data=@partyList TextProperty="DisplayName" 
                    Value=@partyID ValueProperty="PartyID" Change=@(args => OnPartyChanged(args)) AllowClear=true  Placeholder="--Select--" Disabled ="@(!chkClaimant)" Style="width: 100%; max-width: 400px;"/>
                    <span class="alert-dangerMsg" hidden="@(partyList.Count > 0)">@ApplicationConstants.NoDataMsg</span>

@*               <RadzenTextBox class="@LookupData.GetTextColorClass(txtClaimant, firstRendeValue || !chkClaimant )" Disabled ="@(!chkClaimant)"  @bind-Value=@txtClaimant MaxLength="150"  Style="width: 100%; max-width: 400px;"/> 
*@            </div>
        </div>
    </div>
</div>

@code {

    public async ValueTask DisposeAsync()
    {
        LookupData.DocumentSubmitted -= new MyEventHandler(DocumentSubmitted);
    }

    [Parameter]
    public AceDataCollector LookupData { get; set; }

    [Parameter]
    public LoggerUtility Logger { get; set; }
    string txtLossLocation, txtYourClaimNo,txtYourPolicyNo,txtYourInsured,txtYourClient,txtCaseCaption,txtYourFileNo,txtDateofService,txtClaimant = string.Empty;
    bool showLossLoc = true;
    bool chkLossLocation, chkYourClaimNo,chkYourPolicyNo,chkYourInsured,chkYourClient,chkCaseCaption,chkYourFileNo,chkDateofService,chkClaimant = false;
    List<PartyAddressUI> partyList = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            txtLossLocation = ((GCSourceSystemEntity)LookupData.SourceSystemEntity).Claim.LossLocationCity + ", " + ((GCSourceSystemEntity)LookupData.SourceSystemEntity).Claim.LossLocationState;
            showLossLoc = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(showLossLoc), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.FalseString.ToUpper() ? false : true;
            chkLossLocation = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkLossLocation), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkYourClaimNo = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkYourClaimNo), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkYourPolicyNo = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkYourPolicyNo), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkYourInsured = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkYourInsured), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkYourClient = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkYourClient), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkCaseCaption = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkCaseCaption), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkYourFileNo = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkYourFileNo), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkDateofService = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkDateofService), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;
            chkClaimant = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(chkClaimant), LookupData.documentData.documentEntity.DocumentId).ToUpper() == bool.TrueString.ToUpper() ? true : false;

            string claimantRoles;
            claimantRoles = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(claimantRoles), LookupData.documentData.documentEntity.DocumentId);
            var partyFullList = (new MapperClass()).GetMappedObjects(LookupData.SourceSystemEntity);
            if (!string.IsNullOrEmpty(claimantRoles))
            {
                var partyRoles = claimantRoles.Split(',').ToList();
                partyList = partyFullList.Where(x => x.PartyRoles.Any(partyRoles.Contains))?.OrderBy(x=>x.DisplayName)?.ToList();
            }
            if (partyList.Count == 1)
            {
                partyID = partyList.FirstOrDefault()?.PartyID;
                txtClaimant = partyList.Where(x => x.PartyID == partyID).FirstOrDefault()?.DisplayName;
            }
        }
        catch (Exception ex)
        {
            Logger.LogInfoAsync(LogType.Error, ex);
        }
        LookupData.DocumentSubmitted += new MyEventHandler(DocumentSubmitted);
    }
    bool firstRendeValue = true;
    protected override void OnAfterRender(bool firstRender)
    {
        firstRendeValue = firstRender;
    }


    string partyID;
    void OnPartyChanged(object myArgs)
    {
        try
        {
            partyID = myArgs == null ? string.Empty : myArgs.ToString();
            txtClaimant = partyList.Where(x => x.PartyID == myArgs.ToString()).FirstOrDefault()?.DisplayName;
        }
        catch (Exception ex)
        {
            Logger.LogInfoAsync(LogType.Error, ex);
        }
    }


    void DocumentSubmitted(bool isValidate)
    {

        var userSelection = ((GCUserEntity)LookupData.UserSelection).ReSectionDetails = new ReSection();
        if (chkLossLocation)
            if (string.IsNullOrEmpty(txtLossLocation))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.LossLocation = txtLossLocation;
        if (chkYourClaimNo)
            if (string.IsNullOrEmpty(txtYourClaimNo))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.YourClaimNo = txtYourClaimNo;
        if (chkYourPolicyNo)
            if (string.IsNullOrEmpty(txtYourPolicyNo))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.YourPolicyNo = txtYourPolicyNo;
        if (chkYourInsured)
            if (string.IsNullOrEmpty(txtYourInsured))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.YourInsured = txtYourInsured;
        if (chkYourClient)
            if (string.IsNullOrEmpty(txtYourClient))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.YourClient = txtYourClient;
        if (chkCaseCaption)
            if (string.IsNullOrEmpty(txtCaseCaption))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.CaseCaption = txtCaseCaption;
        if (chkYourFileNo)
            if (string.IsNullOrEmpty(txtYourFileNo))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.YourFileNo = txtYourFileNo;
        if (chkDateofService)
            if (string.IsNullOrEmpty(txtDateofService))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.DateofService = txtDateofService;
        if (chkClaimant)
            if (string.IsNullOrEmpty(txtClaimant))
                LookupData.errorDetails.IsInValid = true;
            else
                userSelection.Claimant = txtClaimant;
    }

}
