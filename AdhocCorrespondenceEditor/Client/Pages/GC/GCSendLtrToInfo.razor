@using AdhocCorrespondenceEditor.Client.Common
@using AdhocCorrespondenceEditor.Client.ControlClass
@using AdhocCorrespondenceEditor.Client.PageHelper
@using AdhocCorrespondenceEditor.Shared
@using AdhocCorrespondenceEditor.Shared.DTO.UserInputEntity
@inject HttpClient Http
@using static AdhocCorrespondenceEditor.Client.AceDataCollector
@namespace AdhocCorrespondenceEditor.Client.Shared
<div class="panel panel-primary">
    <div class="panel-heading">
        Sending Letter To
    </div>
    <div class="panel-body">
        <div class="row">
            <div class="col-md-3">
                * Send Letter To:
            </div>
            <div class="col-md-9">
                <RadzenDropDown id="SendLtrTo" class=@($"{@LookupData.GetTextColorClass(sendLtrToInfo, firstRendeValue)} DropDownSize") TextProperty="DocumentDropdownLookupItemCode"
                                ValueProperty="DocumentDropdownLookupItemCode"
                                TValue="string"  Data=@sendLtrToOptions Change=@(args => onSendLtrToInfoChanged(args))
                                AllowClear=true Placeholder="--Select--" Style="width: 100%; max-width: 300px;">
                </RadzenDropDown>
            </div>
        </div>
        @if (showClaimantNm)
        {
            <div class="row">
                <div class="col-md-3">
                    * Claimant Name:
                </div>
                <div class="col-md-9">
                    <RadzenDropDown id="ClaimantNameOnly" class=@($"{@LookupData.GetTextColorClass(displayName, firstRendeValue)} DropDownSize")
                    TValue="PartyAddressUI" Data=@partyList TextProperty="DisplayName" ValueProperty="PartyID"
                                    Change=@(args => OnPartyChanged(args))
                                    AllowClear=true Placeholder="--Select--"   />
                    <span class="alert-dangerMsg" hidden="@(partyList.Count > 0)">@ApplicationConstants.NoDataMsg</span>
                </div>
            </div>
        }
    </div>
</div>

@code {
    List<PartyAddressUI> partyList = new();
    string displayName;
    public async ValueTask DisposeAsync()
    {
        LookupData.DocumentSubmitted -= new MyEventHandler(DocumentSubmitted);
    }
    public string sendLtrToInfo = string.Empty;
    [Parameter]
    public AceDataCollector LookupData { get; set; }

    [Parameter]
    public LoggerUtility Logger { get; set; }
    List<DocumentDropdownLookupDataEntity> sendLtrToOptions = new();
    protected override async Task OnInitializedAsync()
    {
        LookupData.DocumentSubmitted += new MyEventHandler(DocumentSubmitted);
        sendLtrToOptions = (await Http.GetFromJsonAsync<List<DocumentDropdownLookupDataEntity>>($"{ApplicationConstants.UrlDocumentDropDown}{LookupData.LOBName}/{nameof(sendLtrToOptions)}/"));

    }
    bool firstRendeValue = true, showClaimantNm = false;
    protected override void OnAfterRender(bool firstRender)
    {
        firstRendeValue = firstRender;
    }
    void onSendLtrToInfoChanged(object args)
    {
        sendLtrToInfo = args?.ToString();
        showClaimantNm = false;
        if (!string.IsNullOrEmpty(sendLtrToInfo))
        {
            if (sendLtrToInfo == sendLtrToOptions[0].DocumentDropdownLookupItemValue)
            {
                showClaimantNm = true;

                try
                {
                    string claimantRoles;
                    claimantRoles = ApplicationClassUtility.GetVariableText(LookupData.configLookupEntity, nameof(claimantRoles), LookupData.documentData.documentEntity.DocumentId);
                    var partyFullList = (new MapperClass()).GetMappedObjects(LookupData.SourceSystemEntity);
                    if (!string.IsNullOrEmpty(claimantRoles))
                    {
                        var partyRoles = claimantRoles.Split(',').ToList();
                        partyList = partyFullList.Where(x => x.PartyRoles.Any(partyRoles.Contains))?.OrderBy(x => x.DisplayName)?.ToList();
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogInfoAsync(LogType.Error, ex);
                }

            }
        }

    }
    void OnPartyChanged(object myArgs)
    {
        try
        {
            displayName = myArgs == null ? string.Empty : partyList?.Where(x => x?.PartyID == myArgs.ToString()).FirstOrDefault()?.DisplayName;
        }
        catch (Exception ex)
        {
            Logger.LogInfoAsync(LogType.Error, ex);
        }
    }


    void DocumentSubmitted(bool isValidate)
    {
        if (string.IsNullOrEmpty(sendLtrToInfo) || sendLtrToInfo == sendLtrToOptions[0].DocumentDropdownLookupItemValue && string.IsNullOrEmpty(displayName))
        {
            LookupData.errorDetails.IsInValid = true;
            return;
        }
          ((GCUserEntity)LookupData.UserSelection).SendLtrTo = sendLtrToInfo;
        if (sendLtrToInfo == sendLtrToOptions[0].DocumentDropdownLookupItemValue)
        {
            ((GCUserEntity)LookupData.UserSelection).ClaimantNameAddress = new AdhocCorrespondenceEditor.Shared.DTO.UserInputEntity.Address
                {
                    DisplayName = displayName
                };
        }
    }
}